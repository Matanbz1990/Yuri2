# ═══════════════════════════════════════════════════════════
# יורי — Environment Variables
# ═══════════════════════════════════════════════════════════
# העתק קובץ זה ל-.env ומלא את המפתחות שלך
# cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── Gemini API (חובה לפרודקשן) ────────────────────────────
# קבל מפתח חינמי: https://aistudio.google.com/apikey
VITE_GEMINI_KEY=

# ─── Firebase (חובה לאותנטיקציה ושמירת היסטוריה) ───────────
# צור פרויקט: https://console.firebase.google.com
# 1. Authentication → Enable → Google sign-in
# 2. Firestore Database → Create → Start in test mode
# 3. Project Settings → Web app → העתק config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
